# 第三方足球数据 API 密钥 (如 API-Football 或其他提供商)
FOOTBALL_API_KEY="your_api_key_here"

# 大语言模型 API 密钥 (OpenAI, DeepSeek, Claude 等)
LLM_API_KEY="sk-your_llm_api_key_here"
LLM_API_BASE="https://api.openai.com/v1" # 如果用第三方转发或DeepSeek需修改
LLM_MODEL="gpt-4o" # 使用的模型名称

# 数据库配置 (默认 SQLite)
DATABASE_URL="sqlite:///data/football.db"

# 消息推送 (如钉钉 webhook 或 Telegram Bot Token)
DINGTALK_WEBHOOK="your_dingtalk_webhook_here"
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_CHAT_ID="your_chat_id"
